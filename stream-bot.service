[Unit]
Description=Khdiamond Telegram Stream Bot
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/stream-bot
EnvironmentFile=/opt/stream-bot/.env
ExecStart=/opt/stream-bot/stream-bot
Restart=always
RestartSec=5
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/stream-bot

[Install]
WantedBy=multi-user.target
